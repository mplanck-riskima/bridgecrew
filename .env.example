DISCORD_TOKEN=your-bot-token-here
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-channel-id
WORKSPACE_DIR=/path/to/your/projects

# Dashboard API integration
BRIDGECREW_API_URL=http://localhost:8000
BRIDGECREW_API_KEY=your-api-key-here

# MongoDB (required for dashboard)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/bridgecrew_dev?retryWrites=true&w=majority
MONGODB_DATABASE=bridgecrew_dev

# Dashboard CORS
ALLOWED_ORIGINS=http://localhost:5173
